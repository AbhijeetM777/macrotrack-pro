{
  "name": "macrotrack-pro",
  "version": "2.0.0",
  "description": "Advanced Fitness & Macro Tracker - Progressive Web App with Cloud Sync",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "lint": "eslint lib/ tests/",
    "format": "prettier --write 'lib/**/*.js' 'tests/**/*.js'",
    "type-check": "tsc --noEmit",
    "server": "node server.js"
  },
  "keywords": [
    "fitness",
    "macro-tracking",
    "pwa",
    "workout",
    "nutrition",
    "health"
  ],
  "author": "Abhijeet M",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/dom": "^9.3.4",
    "@testing-library/user-event": "^14.5.1",
    "@vitejs/plugin-vue": "^4.5.2",
    "@vitest/coverage-v8": "^1.2.2",
    "@vitest/ui": "^1.2.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.1",
    "vitest": "^1.2.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.6"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
